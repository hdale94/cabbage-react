	"type": "module",
	"keywords": [
		"cabbage",
		"react"
	],
	"author": "Håkon Dale",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hdale94/cabbage-react.git"
	},
